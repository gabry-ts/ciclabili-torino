---
import "../styles/global.css";
import ThemeBootstrap from "../components/ThemeBootstrap.astro";

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const {
  title,
  description = "Mappa interattiva delle piste ciclabili di Torino con dati live dai contatori del Comune.",
  bodyClass,
} = Astro.props;
---
<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <title>{title}</title>

    <ThemeBootstrap />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <div class="grid-bg" aria-hidden="true"></div>

    <slot />

    <script>
      import "../scripts/theme.ts";
    </script>
  </body>
</html>
